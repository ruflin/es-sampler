# es-sampler environment variables.
#
# Copy this file to `.env` and fill in the values you need:
#   cp .env.example .env
#
# `es-sampler` auto-loads `.env` from the current directory on start. Pass
# --env-file=PATH to point at a different file.
#
# Precedence (highest first): CLI flag > shell env var > .env > default.
# Values already exported in the shell always win over this file.

# --- Source cluster (required) ------------------------------------------------
SOURCE_ELASTICSEARCH_HOST=https://source.example.cloud.es.io:443
SOURCE_ELASTICSEARCH_API_KEY=

# --- Destination cluster ------------------------------------------------------
# Defaults: http://localhost:9200, elastic / changeme.
# When ELASTICSEARCH_API_KEY is set it takes precedence over username/password.
ELASTICSEARCH_HOST=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme
# ELASTICSEARCH_API_KEY=

# --- Sync options -------------------------------------------------------------
# Index pattern to sample from on the source cluster.
SYNC_INDEX_PATTERN=logs*

# Number of docs fetched per cycle.
SYNC_SIZE=100

# Seconds to wait between cycles.
SYNC_INTERVAL_SECONDS=1

# Lookback window for each search, as a Go duration (e.g. 15m, 2h30m, 24h).
# The window always ends at "now".
SYNC_LOOKBACK=24h

# Fixed seed for sampling (omit to use a run-based seed).
# SYNC_RANDOM_SEED=

# If set, all docs are pushed to this single data stream / index.
# Otherwise the original index / stream name is preserved.
# SYNC_TARGET_INDEX=

# Bulk batch size when pushing to the destination.
SYNC_BATCH_SIZE=100
